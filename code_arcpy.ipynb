{
  "cells": [
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "# Endangered plant species habitat workflow\n",
        "\n",
        "ArcGIS Pro / ArcPy notebook template.\n",
        "\n",
        "Run this notebook in an ArcGIS Pro Python environment where `arcpy` is available.\n",
        "\n",
        "The workflow follows the described lineage:\n",
        "1. Species occurrence layer\n",
        "2. Basic habitat layer\n",
        "3. Current occurrence habitats\n",
        "4. Potential dispersal habitats\n",
        "5. Species frequency maps\n",
        "6. Final outputs for all protection categories and C1 + C2 + C3\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# -*- coding: utf-8 -*-\n",
        "\n",
        "import arcpy\n",
        "import os\n",
        "\n",
        "arcpy.env.overwriteOutput = True\n"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 0. Input paths and fields\n",
        "\n",
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "gdb = r\"C:\\GIS\\Endangered_species\\workflow.gdb\"\n",
        "arcpy.env.workspace = gdb\n",
        "\n",
        "pladias_points = r\"C:\\GIS\\input\\PLADIAS_points.shp\"\n",
        "ndop_points = r\"C:\\GIS\\input\\NDOP_points.shp\"\n",
        "ndop_lines = r\"C:\\GIS\\input\\NDOP_lines.shp\"\n",
        "ndop_polygons = r\"C:\\GIS\\input\\NDOP_polygons.shp\"\n",
        "\n",
        "habitat_map_2024 = r\"C:\\GIS\\input\\habitat_map_2024.shp\"\n",
        "kves_2023 = r\"C:\\GIS\\input\\KVES_2023.shp\"\n",
        "\n",
        "sadlo_table = r\"C:\\GIS\\input\\sadlo_species_habitats.csv\"\n",
        "dispersal_table = r\"C:\\GIS\\input\\lososova_dispersal.csv\"\n",
        "\n",
        "species_field = \"SPECIES\"\n",
        "precision_field = \"GPS_PREC\"\n",
        "habitat_field = \"HAB_CODE\"\n",
        "protection_field = \"PROTECTION\"\n",
        "dispersal_field = \"DISP_CLASS\"\n",
        "\n",
        "area_threshold = 5\n",
        "large_reservoir_area = 5000000\n"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 1. Species occurrence layer\n",
        "\n",
        "Points and lines are buffered by 1 m. Huge NDOP grid polygons are removed. Low-precision polygons are narrowed to 400 m around their centroid.\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "pladias_poly = \"pladias_points_buf1m\"\n",
        "ndop_points_poly = \"ndop_points_buf1m\"\n",
        "ndop_lines_poly = \"ndop_lines_buf1m\"\n",
        "ndop_polygons_clean = \"ndop_polygons_clean\"\n",
        "\n",
        "arcpy.analysis.Buffer(pladias_points, pladias_poly, \"1 Meters\")\n",
        "arcpy.analysis.Buffer(ndop_points, ndop_points_poly, \"1 Meters\")\n",
        "arcpy.analysis.Buffer(ndop_lines, ndop_lines_poly, \"1 Meters\")\n",
        "\n",
        "# Remove huge square polygons of 3 x 3 km and larger.\n",
        "arcpy.management.MakeFeatureLayer(\n",
        "    ndop_polygons,\n",
        "    \"ndop_poly_lyr\",\n",
        "    \"Shape_Area < 9000000\"\n",
        ")\n",
        "arcpy.management.CopyFeatures(\"ndop_poly_lyr\", ndop_polygons_clean)\n",
        "\n",
        "# Narrow low-precision polygons to 400 m around centroid.\n",
        "centroids = \"ndop_low_precision_centroids\"\n",
        "centroid_buffers = \"ndop_low_precision_400m\"\n",
        "\n",
        "arcpy.management.MakeFeatureLayer(\n",
        "    ndop_polygons_clean,\n",
        "    \"low_precision_poly\",\n",
        "    f\"{precision_field} > 400\"\n",
        ")\n",
        "\n",
        "arcpy.management.FeatureToPoint(\"low_precision_poly\", centroids, \"INSIDE\")\n",
        "arcpy.analysis.Buffer(centroids, centroid_buffers, \"400 Meters\")\n",
        "\n",
        "arcpy.management.MakeFeatureLayer(\n",
        "    ndop_polygons_clean,\n",
        "    \"precise_poly\",\n",
        "    f\"{precision_field} <= 400\"\n",
        ")\n",
        "\n",
        "ndop_polygons_adjusted = \"ndop_polygons_adjusted\"\n",
        "arcpy.management.Merge([\"precise_poly\", centroid_buffers], ndop_polygons_adjusted)\n",
        "\n",
        "species_occ_raw = \"species_occurrences_raw\"\n",
        "arcpy.management.Merge(\n",
        "    [pladias_poly, ndop_points_poly, ndop_lines_poly, ndop_polygons_adjusted],\n",
        "    species_occ_raw\n",
        ")\n",
        "\n",
        "# Simplified duplicate handling.\n",
        "# For intersecting but not identical duplicates, add a project-specific spatial duplicate rule.\n",
        "species_occ_sorted = \"species_occurrences_sorted\"\n",
        "species_occurrence_layer = \"species_occurrence_layer\"\n",
        "\n",
        "arcpy.management.Sort(\n",
        "    species_occ_raw,\n",
        "    species_occ_sorted,\n",
        "    [[species_field, \"ASCENDING\"], [precision_field, \"ASCENDING\"]]\n",
        ")\n",
        "\n",
        "arcpy.management.DeleteIdentical(species_occ_sorted, [species_field, \"Shape\"])\n",
        "arcpy.management.CopyFeatures(species_occ_sorted, species_occurrence_layer)\n",
        "\n",
        "print(\"Species occurrence layer created:\", species_occurrence_layer)\n"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 2. Basic habitat layer\n",
        "\n",
        "Intersect the Czech Republic habitat map 2024 and KVES 2023 to unify the legend.\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "basic_habitat_layer = \"basic_habitat_layer\"\n",
        "\n",
        "arcpy.analysis.Intersect(\n",
        "    [habitat_map_2024, kves_2023],\n",
        "    basic_habitat_layer,\n",
        "    \"ALL\"\n",
        ")\n",
        "\n",
        "print(\"Basic habitat layer created:\", basic_habitat_layer)\n"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 3. Current occurrence habitats\n",
        "\n",
        "Precise occurrences are preserved in full. Less precise occurrences are filtered by species-habitat appropriateness.\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "current_intersect = \"current_occurrence_intersect\"\n",
        "\n",
        "arcpy.analysis.Intersect(\n",
        "    [basic_habitat_layer, species_occurrence_layer],\n",
        "    current_intersect,\n",
        "    \"ALL\"\n",
        ")\n",
        "\n",
        "# Expected appropriateness table fields:\n",
        "# SPECIES, HAB_CODE, APPROPRIATE\n",
        "arcpy.management.JoinField(\n",
        "    current_intersect,\n",
        "    species_field,\n",
        "    sadlo_table,\n",
        "    species_field,\n",
        "    [habitat_field, \"APPROPRIATE\"]\n",
        ")\n",
        "\n",
        "current_selected = \"current_occurrence_habitats\"\n",
        "\n",
        "where_current = (\n",
        "    f\"{precision_field} <= 20 OR \"\n",
        "    f\"({precision_field} > 20 AND APPROPRIATE = 1)\"\n",
        ")\n",
        "\n",
        "arcpy.management.MakeFeatureLayer(current_intersect, \"current_selected_lyr\", where_current)\n",
        "arcpy.management.CopyFeatures(\"current_selected_lyr\", current_selected)\n",
        "\n",
        "print(\"Current occurrence habitats created:\", current_selected)\n"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 4. Narrow large forests, anthropogenic habitats and reservoirs\n",
        "\n",
        "Replace the example habitat codes with your real codes. Large forest, anthropogenic, and reservoir polygons are clipped by a 400 m buffer around occurrence polygons.\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "forest_codes = (\"FOREST\",)\n",
        "anthropogenic_codes = (\"URBAN\", \"INDUSTRIAL\")\n",
        "reservoir_codes = (\"RESERVOIR\",)\n",
        "\n",
        "forest_sql = \",\".join([f\"'{x}'\" for x in forest_codes])\n",
        "anthro_sql = \",\".join([f\"'{x}'\" for x in anthropogenic_codes])\n",
        "reservoir_sql = \",\".join([f\"'{x}'\" for x in reservoir_codes])\n",
        "\n",
        "large_where = (\n",
        "    f\"{habitat_field} IN ({forest_sql}, {anthro_sql}) OR \"\n",
        "    f\"({habitat_field} IN ({reservoir_sql}) AND Shape_Area > {large_reservoir_area})\"\n",
        ")\n",
        "\n",
        "large_sensitive = \"large_sensitive_polygons\"\n",
        "large_sensitive_buffer = \"large_sensitive_buffer_400m\"\n",
        "large_clipped = \"large_sensitive_clipped\"\n",
        "current_occurrence_narrowed = \"current_occurrence_habitats_narrowed\"\n",
        "\n",
        "arcpy.management.MakeFeatureLayer(current_selected, \"large_sensitive_lyr\", large_where)\n",
        "arcpy.management.CopyFeatures(\"large_sensitive_lyr\", large_sensitive)\n",
        "\n",
        "arcpy.analysis.Buffer(species_occurrence_layer, large_sensitive_buffer, \"400 Meters\")\n",
        "arcpy.analysis.Clip(large_sensitive, large_sensitive_buffer, large_clipped)\n",
        "\n",
        "arcpy.management.MakeFeatureLayer(current_selected, \"normal_current_lyr\", f\"NOT ({large_where})\")\n",
        "\n",
        "arcpy.management.Merge(\n",
        "    [\"normal_current_lyr\", large_clipped],\n",
        "    current_occurrence_narrowed\n",
        ")\n",
        "\n",
        "print(\"Current occurrence habitats after narrowing:\", current_occurrence_narrowed)\n"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 5. Potential dispersal habitats\n",
        "\n",
        "Classes 1-3 stay in current occurrence polygons. Class 4 uses 150 m. Classes 5-6 use 500 m.\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "arcpy.management.JoinField(\n",
        "    current_occurrence_narrowed,\n",
        "    species_field,\n",
        "    dispersal_table,\n",
        "    species_field,\n",
        "    [dispersal_field]\n",
        ")\n",
        "\n",
        "potential_parts = []\n",
        "\n",
        "# Classes 1-3: no dispersal\n",
        "arcpy.management.MakeFeatureLayer(\n",
        "    current_occurrence_narrowed,\n",
        "    \"disp_1_3\",\n",
        "    f\"{dispersal_field} IN (1, 2, 3)\"\n",
        ")\n",
        "\n",
        "disp_1_3_out = \"potential_disp_1_3\"\n",
        "arcpy.management.CopyFeatures(\"disp_1_3\", disp_1_3_out)\n",
        "potential_parts.append(disp_1_3_out)\n",
        "\n",
        "# Class 4: 150 m\n",
        "arcpy.management.MakeFeatureLayer(\n",
        "    current_occurrence_narrowed,\n",
        "    \"disp_4\",\n",
        "    f\"{dispersal_field} = 4\"\n",
        ")\n",
        "\n",
        "disp_4_buffer = \"disp_4_buffer_150m\"\n",
        "disp_4_habitats = \"potential_disp_4\"\n",
        "\n",
        "arcpy.analysis.Buffer(\"disp_4\", disp_4_buffer, \"150 Meters\")\n",
        "arcpy.analysis.Intersect([basic_habitat_layer, disp_4_buffer], disp_4_habitats, \"ALL\")\n",
        "potential_parts.append(disp_4_habitats)\n",
        "\n",
        "# Classes 5-6: 500 m\n",
        "arcpy.management.MakeFeatureLayer(\n",
        "    current_occurrence_narrowed,\n",
        "    \"disp_5_6\",\n",
        "    f\"{dispersal_field} IN (5, 6)\"\n",
        ")\n",
        "\n",
        "disp_5_6_buffer = \"disp_5_6_buffer_500m\"\n",
        "disp_5_6_habitats = \"potential_disp_5_6\"\n",
        "\n",
        "arcpy.analysis.Buffer(\"disp_5_6\", disp_5_6_buffer, \"500 Meters\")\n",
        "arcpy.analysis.Intersect([basic_habitat_layer, disp_5_6_buffer], disp_5_6_habitats, \"ALL\")\n",
        "potential_parts.append(disp_5_6_habitats)\n",
        "\n",
        "potential_occurrence = \"potential_occurrence_habitats\"\n",
        "arcpy.management.Merge(potential_parts, potential_occurrence)\n",
        "\n",
        "print(\"Potential occurrence habitats created:\", potential_occurrence)\n"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 6. Remove polygons smaller than 5 m²"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "potential_clean = \"potential_occurrence_clean\"\n",
        "\n",
        "arcpy.management.MakeFeatureLayer(\n",
        "    potential_occurrence,\n",
        "    \"potential_clean_lyr\",\n",
        "    f\"Shape_Area >= {area_threshold}\"\n",
        ")\n",
        "\n",
        "arcpy.management.CopyFeatures(\"potential_clean_lyr\", potential_clean)\n",
        "\n",
        "print(\"Small polygons removed:\", potential_clean)\n"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 7. Count species per polygon geometry and dissolve by COUNT\n",
        "\n",
        "This is a template. Depending on your overlap structure, the species counting step may need a more detailed workflow using `FeatureToPolygon`, `SpatialJoin`, `Identity`, or pairwise tools.\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "identity_layer = \"potential_identity\"\n",
        "count_table = \"species_count_by_polygon\"\n",
        "final_all_categories = \"final_potential_frequency_all_categories\"\n",
        "\n",
        "arcpy.analysis.Union([potential_clean], identity_layer, \"ALL\")\n",
        "\n",
        "arcpy.analysis.Frequency(\n",
        "    identity_layer,\n",
        "    count_table,\n",
        "    [\"OBJECTID\"],\n",
        "    [species_field]\n",
        ")\n",
        "\n",
        "arcpy.management.JoinField(\n",
        "    identity_layer,\n",
        "    \"OBJECTID\",\n",
        "    count_table,\n",
        "    \"OBJECTID\",\n",
        "    [\"FREQUENCY\"]\n",
        ")\n",
        "\n",
        "arcpy.management.AlterField(identity_layer, \"FREQUENCY\", \"COUNT\", \"COUNT\")\n",
        "\n",
        "arcpy.management.Dissolve(\n",
        "    identity_layer,\n",
        "    final_all_categories,\n",
        "    [\"COUNT\"],\n",
        "    multi_part=\"MULTI_PART\",\n",
        "    unsplit_lines=\"DISSOLVE_LINES\"\n",
        ")\n",
        "\n",
        "print(\"Final all-category frequency map:\", final_all_categories)\n"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 8. C1 + C2 + C3 version"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "c123_layer = \"potential_C1_C2_C3\"\n",
        "identity_c123 = \"potential_identity_C1_C2_C3\"\n",
        "count_table_c123 = \"species_count_by_polygon_C1_C2_C3\"\n",
        "final_c123 = \"final_potential_frequency_C1_C2_C3\"\n",
        "\n",
        "arcpy.management.MakeFeatureLayer(\n",
        "    potential_clean,\n",
        "    \"c123_lyr\",\n",
        "    f\"{protection_field} IN ('C1', 'C2', 'C3')\"\n",
        ")\n",
        "\n",
        "arcpy.management.CopyFeatures(\"c123_lyr\", c123_layer)\n",
        "\n",
        "arcpy.analysis.Union([c123_layer], identity_c123, \"ALL\")\n",
        "\n",
        "arcpy.analysis.Frequency(\n",
        "    identity_c123,\n",
        "    count_table_c123,\n",
        "    [\"OBJECTID\"],\n",
        "    [species_field]\n",
        ")\n",
        "\n",
        "arcpy.management.JoinField(\n",
        "    identity_c123,\n",
        "    \"OBJECTID\",\n",
        "    count_table_c123,\n",
        "    \"OBJECTID\",\n",
        "    [\"FREQUENCY\"]\n",
        ")\n",
        "\n",
        "arcpy.management.AlterField(identity_c123, \"FREQUENCY\", \"COUNT\", \"COUNT\")\n",
        "\n",
        "arcpy.management.Dissolve(\n",
        "    identity_c123,\n",
        "    final_c123,\n",
        "    [\"COUNT\"],\n",
        "    multi_part=\"MULTI_PART\",\n",
        "    unsplit_lines=\"DISSOLVE_LINES\"\n",
        ")\n",
        "\n",
        "print(\"Final C1 + C2 + C3 frequency map:\", final_c123)\n"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 9. Logical consistency check\n",
        "\n",
        "Topological consistency should be checked to ensure no overlaps between polygons representing different `COUNT` values.\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "print(\"Workflow completed.\")\n",
        "print(\"Final outputs:\")\n",
        "print(\" -\", final_all_categories)\n",
        "print(\" -\", final_c123)\n"
      ]
    }
  ],
